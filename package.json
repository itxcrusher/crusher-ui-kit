{
  "name": "crusher-ui-kit",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/crusher-ui.min.js",
  "module": "./dist/crusher-ui.esm.js",
  "scripts": {
    "dev": "vite",
    "build:tokens": "node ./scripts/build-tokens.mjs",
    "check:contrast": "node ./scripts/check-contrast.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:tokens && npm run check:contrast && npm run build",
    "changeset": "changeset",
    "release:prepare": "npx changeset",
    "release:version": "npx changeset version",
    "release:publish": "npm publish --provenance --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "eslint": "^9.11.0",
    "eslint-plugin-lit": "^1.12.0",
    "eslint-plugin-wc": "^2.0.4",
    "lit": "^3.3.1",
    "prettier": "^3.3.3",
    "sass": "^1.77.4",
    "style-dictionary": "^5.0.2",
    "vite": "^7.1.4"
  },
  "sideEffects": [
    "src/css/**",
    "src/scss/**",
    "src/js/main.js",
    "src/components/**",
    "src/runtime/**"
  ],
  "exports": {
    ".": {
      "import": "./dist/crusher-ui.esm.js",
      "require": "./dist/crusher-ui.min.js",
      "default": "./dist/crusher-ui.esm.js"
    },
    "./runtime": {
      "types": "./types/runtime.d.ts",
      "import": "./src/runtime/command-palette.js",
      "default": "./src/runtime/command-palette.js"
    },
    "./styles/tokens.css": "./src/css/tokens.css",
    "./styles/modes.css": "./src/css/modes.css",
    "./styles/semantic.css": "./src/css/semantic.css",
    "./styles/bridge.css": "./src/css/bridge.css",
    "./styles/code-theme.css": "./src/css/code-theme.css",
    "./styles/theme-scenes.css": "./src/css/theme-scenes.css",
    "./styles/dialect-overrides.css": "./src/css/dialect-overrides.css",
    "./themes/*.css": "./src/css/themes/*.css"
  },
  "files": [
    "dist",
    "src/css",
    "src/runtime",
    "types",
    "LICENSE",
    "README.md"
  ],
  "types": "./types/index.d.ts",
  "typesVersions": {
    "*": {
      "runtime": [
        "types/runtime.d.ts"
      ]
    }
  },
  "keywords": [
    "design-tokens",
    "lit",
    "ui-kit",
    "web-components",
    "themes",
    "style-dictionary"
  ],
  "author": "Muhammad Hassaan Javed",
  "engines": {
    "node": ">=20.19.0 || >=22.0.0"
  }
}
