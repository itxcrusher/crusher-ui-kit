      "width": { "value": "{focus.width}" }
    }
  },

  "transition": {
    "duration": {
      "fast": { "value": "100ms" },
      "base": { "value": "200ms" },
      "slow": { "value": "400ms" }
    },
    "easing": {
      "inout": { "value": "cubic-bezier(0.4,0,0.2,1)" }
    }
  },

  "component": {
    "radius":       { "value": "{radius.md}" },
    "borderWeight": { "value": "1px" },
    "elevation":    { "value": "{shadow.2}" },
    "control": {
      "bg":        { "value": "{color.brand.primary}" },
      "fg":        { "value": "{color.base.white}" },
      "hoverLift": { "value": "translateY(-2px)" }
